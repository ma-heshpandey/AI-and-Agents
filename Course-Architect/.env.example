# AWS credentials (for Amazon Bedrock)
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_DEFAULT_REGION=us-east-1

# Any Bedrock model that supports tool use / function calling
AWS_BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-5-20250929-v1:0

# Optional: use the Anthropic API directly instead of Bedrock
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: default topic if none is passed on the command line
COURSE_TOPIC=Introduction to Machine Learning

# Optional: Langfuse tracing (set to true and fill in all three keys to enable)
LANGFUSE_ENABLED=false
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_BASE_URL=http://localhost:3000

# AWS Credentials (for Amazon Bedrock)
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_DEFAULT_REGION=us-east-1

# Bedrock Model ID
# Options:
#   us.anthropic.claude-3-7-sonnet-20250219-v1:0  (Claude 3.7 Sonnet - recommended)
#   us.anthropic.claude-3-5-sonnet-20241022-v2:0  (Claude 3.5 Sonnet)
#   us.anthropic.claude-3-haiku-20240307-v1:0      (Claude Haiku - faster/cheaper)
#   amazon.nova-pro-v1:0                           (Amazon Nova Pro)
AWS_BEDROCK_MODEL_ID=us.anthropic.claude-3-7-sonnet-20250219-v1:0

# Optional: Use Anthropic API directly instead of Bedrock
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Course topic (can also be passed as CLI argument)
COURSE_TOPIC=Introduction to Machine Learning

# Langfuse tracing (optional) — disabled by default.
# Set LANGFUSE_ENABLED=true AND fill in all three keys below to enable it.
LANGFUSE_ENABLED=false
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_BASE_URL=http://localhost:3000
